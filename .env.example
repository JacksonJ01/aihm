# Required: Supabase browser and server clients use these in all environments.
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Recommended in hosted environments: used to build auth callback URLs.
# Set this to your canonical deployed origin, for example:
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
# or
# SITE_URL=https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=

# Required in production if login, sign up, forgot password, or password reset
# forms should work. In local development, auth forms can bypass Turnstile when
# these are unset.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
